#!/usr/bin/env bash
# pre-commit hook: auto-fix non-LaTeX characters in LaTeX source files.
#
# Canonical location: claude-config/scripts/pre-commit-bib
# Installed by setup.sh to .git/hooks/pre-commit in repos containing
# LaTeX files (.tex, .bib, .bst, .cls, .sty).
#
# The fixer script (fix-bib-unicode.py) is resolved relative to this file
# when symlinked, or falls back to ~/Claude/claude-config/scripts/.

set -euo pipefail

# Locate fix-bib-unicode.py:
#   1. Follow symlink to find the canonical scripts/ directory
#   2. Fall back to ~/Claude/claude-config/scripts/
SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
SCRIPTS_DIR="$(cd "$(dirname "$SELF")" && pwd)"
FIXER="$SCRIPTS_DIR/fix-bib-unicode.py"

if [[ ! -f "$FIXER" ]]; then
    # Fallback for Windows (cp install) where readlink may not resolve
    FIXER="$HOME/Claude/claude-config/scripts/fix-bib-unicode.py"
fi

# LaTeX Unicode fix — runs only when the fixer exists AND LaTeX files are staged.
# CRITICAL: do NOT early-exit on "no fixer" / "no LaTeX files". The layer-3
# custom hook chain below must run on EVERY commit (incl. pure non-LaTeX, e.g.
# yaml-only commits), otherwise data/yaml gates silently never fire. (2026-06-06
# RCA: a refs.yaml-only commit with a duplicate was NOT rejected because this
# early-exit skipped the custom hook.)
if [[ -f "$FIXER" ]]; then
    LATEX_FILES=$(git diff --cached --name-only --diff-filter=ACM \
        | grep -E '\.(tex|bib|bst|cls|sty)$' || true)
    if [[ -n "$LATEX_FILES" ]]; then
        # Run the fixer (exit 1 = files were modified, 0 = no changes)
        python3 "$FIXER" $LATEX_FILES && rc=0 || rc=$?
        if [[ $rc -eq 1 ]]; then
            for f in $LATEX_FILES; do
                git add "$f"
            done
            echo "pre-commit: auto-fixed non-LaTeX characters and re-staged."
        elif [[ $rc -ge 2 ]]; then
            echo "pre-commit: fix-bib-unicode.py failed (exit $rc)." >&2
            exit 1
        fi
    fi
else
    echo "pre-commit: fix-bib-unicode.py not found. Skipping LaTeX check." >&2
fi

# Optional chain to layer-3 (= personal layer) custom hook.
# odakin-prefs/scripts/pre-commit-yaml-scan.sh があれば呼ぶ。 他 user で本 file
# 不在なら silent skip (= layer 3 不在の他 Claude Code user の env に影響なし)。
# 詳細: ~/Claude/odakin-prefs/scripts/pre-commit-yaml-scan.sh
CUSTOM_HOOK="$HOME/Claude/odakin-prefs/scripts/pre-commit-yaml-scan.sh"
if [[ -x "$CUSTOM_HOOK" ]]; then
    "$CUSTOM_HOOK"  # set -e で exit 1 propagate
fi

exit 0
