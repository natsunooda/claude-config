#!/usr/bin/env bash
# overleaf-sync.sh — Overleaf 同期 script の汎用 template。
#
# 使い方 (推奨 = 1 コマンド設置):
#   bash <claude-config>/scripts/install-overleaf-sync.sh <repo_dir> <Overleaf URL か 24 桁 hex ID>
# 手動でやるなら: 本 file を paper repo の scripts/overleaf-sync.sh に copy し、
#   1. PROJECT_ID を記入 (= Overleaf web → Menu → Git の clone URL 末尾 24 桁 hex)
#   2. MERGE_OPTS を repo の conflict 方針に合わせて調整
#   3. chmod +x して commit (= PROJECT_ID の single source of truth になる)
# 契約の正本 = conventions/overleaf-integration.md §Sync script 契約。
# 横断監視 = scripts/check-overleaf-drift.py (個人層 dashboard から呼ぶ)。
#
# この template は「direct remote + 手動 merge」 変種 (= 共著者は Overleaf を直接編集、
# owner が fetch + merge で GitHub repo へ取込み) 用。 nested clone 変種 (= Overleaf が
# 唯一の source) は conventions/overleaf-integration.md §変種 を参照して書き換える。
#
# 設計 (= 三例目 2026-06-12 RCA の再発防止):
#   - PROJECT_ID を本 script に hardcode = ID を手で持ち回らない恒久記録
#   - token は ~/.secrets/overleaf-token に隔離 (repo に commit しない)。
#     remote は .git/config に永続化せず、 fetch 時に URL 直指定 (token 非永続)
#   - Overleaf への push は共著者に直接影響 → 実装しない (user 明示 OK の手動操作)
#   - 連携を廃止したら本 script を削除せず冒頭で DEPRECATED を表示して exit 0 に置換
#
# Usage:
#   bash scripts/overleaf-sync.sh            # fetch + ahead/behind 表示 (read-only)
#   bash scripts/overleaf-sync.sh --status   # 同上 (check-overleaf-drift.py 用)
#   bash scripts/overleaf-sync.sh --merge    # fetch + overleaf/master を merge

set -euo pipefail

# FIXME_PROJECT_ID: 未設定の間は exit 2 で拒否し、 check-overleaf-drift.py が
# CRITICAL で surface し続ける。
PROJECT_ID="FIXME_PROJECT_ID"

# conflict 方針 (repo の CLAUDE.md に明記したものと一致させる):
#   Overleaf 側採用 = "-X theirs" / local 側採用 = "-X ours" / 手動解決 = ""
MERGE_OPTS="-X theirs"

# local が恒常的に ahead になる運用 (= CLAUDE.md / scripts 等の管理 commit を Overleaf に
# push しない方針) なら 1 にすると、 status 行に ahead-expected marker が付き
# check-overleaf-drift.py が ahead INFO を出さなくなる (behind 検出には影響しない)
AHEAD_EXPECTED=0

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TOKEN_FILE="$HOME/.secrets/overleaf-token"

mask() { sed -E 's/olp_[A-Za-z0-9]+/olp_REDACTED/g'; }
run_git() { "$@" 2>&1 | mask; return "${PIPESTATUS[0]}"; }

if [ "$PROJECT_ID" = "FIXME_PROJECT_ID" ]; then
  echo "[overleaf-sync] PROJECT_ID 未設定。 Overleaf web → Menu → Git の URL から ID を" >&2
  echo "[overleaf-sync] 本 script 冒頭の PROJECT_ID に記入して commit してください。" >&2
  exit 2
fi

if [ ! -s "$TOKEN_FILE" ]; then
  echo "[overleaf-sync] ~/.secrets/overleaf-token が無い。" >&2
  echo "[overleaf-sync] 発行: Overleaf web → Account Settings → Git Integration → Generate token" >&2
  echo "[overleaf-sync] 配置: mode 600 で $TOKEN_FILE に保存 (個人層に復元 script があればそれを使う)" >&2
  exit 2
fi
TOKEN="$(tr -d '\n' < "$TOKEN_FILE")"
REMOTE_URL="https://git:${TOKEN}@git.overleaf.com/${PROJECT_ID}"

MODE="${1:---status}"

# --- fetch (全 mode 共通、 token は config に永続化しない) -------------------
if ! run_git git -C "$REPO_ROOT" fetch "$REMOTE_URL" "+master:refs/remotes/overleaf/master"; then
  echo "[overleaf-sync] fetch 失敗。 token 期限切れ or 権限 or network を確認。" >&2
  exit 1
fi

AHEAD=$(git -C "$REPO_ROOT" rev-list --count overleaf/master..HEAD 2>/dev/null || echo "?")
BEHIND=$(git -C "$REPO_ROOT" rev-list --count HEAD..overleaf/master 2>/dev/null || echo "?")
MARK=""
[ "$AHEAD_EXPECTED" = "1" ] && MARK=" ahead-expected"
echo "[overleaf-sync] ahead=$AHEAD behind=$BEHIND$MARK"

case "$MODE" in
  --status|status)
    if [ "$BEHIND" != "0" ] && [ "$BEHIND" != "?" ]; then
      echo "[overleaf-sync] ⚠️ Overleaf に未取込みの編集 $BEHIND commits。 取り込みは:" >&2
      echo "    bash scripts/overleaf-sync.sh --merge" >&2
    fi
    ;;
  --merge|merge)
    if [ "$BEHIND" = "0" ]; then
      echo "[overleaf-sync] 取り込み済 (behind=0)。 merge 不要。"
      exit 0
    fi
    if [ -n "$(git -C "$REPO_ROOT" status --porcelain)" ]; then
      echo "[overleaf-sync] working tree が dirty。 commit/stash してから --merge を再実行。" >&2
      exit 1
    fi
    echo "[overleaf-sync] merge: overleaf/master → $(git -C "$REPO_ROOT" branch --show-current) (MERGE_OPTS=$MERGE_OPTS)"
    # shellcheck disable=SC2086  # MERGE_OPTS は意図的に語分割
    if ! run_git git -C "$REPO_ROOT" merge $MERGE_OPTS --no-edit overleaf/master; then
      echo "[overleaf-sync] merge 失敗。 手動解決が必要 (repo の conflict 方針に従う)。" >&2
      exit 1
    fi
    echo "[overleaf-sync] merge 完了。 repo 規定のマージ後チェックを実施してから push してください。" >&2
    ;;
  *)
    echo "[overleaf-sync] 不明な mode: $MODE (--status / --merge)" >&2
    exit 2
    ;;
esac
